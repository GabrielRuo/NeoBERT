# Copy this file to .env and fill in your actual credentials.
# .env is gitignored; .env.example is safe to commit.

# Hugging Face access token (https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# Weights & Biases API key (https://wandb.ai/authorize)
WANDB_API_KEY=your_wandb_api_key_here

# Modal API token pair (https://modal.com/settings/tokens)
# once you logged in to modal, you can find these by default in $HOME/.modal/token.json, or you can create new ones in the Modal UI.
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here


